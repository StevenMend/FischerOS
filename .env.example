# ═══════════════════════════════════════════
# FischerOS Environment Variables
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# Supabase (required)
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key-here"

# Demo Mode — set to "true" for sales demos (toasts instead of emails/charges)
VITE_DEMO_MODE="false"

# Stripe (leave empty for demo mode — plug in when ready)
VITE_STRIPE_PUBLISHABLE_KEY=""
